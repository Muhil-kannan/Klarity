# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# ── GitHub App ────────────────────────────────────────────────────────────────
# Create your GitHub App at: https://github.com/settings/apps/new
GITHUB_APP_ID=your_app_id_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Paste your private key contents here (replace newlines with \n)
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----

# For dashboard OAuth (optional for v0.1)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////app/data/klarity.db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
